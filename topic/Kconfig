# topic/Kconfig — 线程间数据通道
# 基于 zbus 定义模块间通信的 topic（发布/订阅）
# 每一对 config 定义一个 topic，select ZBUS
# 头文件在 topic/ 下

config TPC_CHASSIS_TO_CAN
    default n
    bool "Chassis- CAN channel"
    select ZBUS
    help
        chassis 发布 → can_tx 订阅

config TPC_REMOTE_TO
    default n
    bool "Remote channel"
    select ZBUS
    help
        遥控器数据 zbus 通道

# 根 Kconfig — 项目入口门禁
# 定义 CONFIG_PRJ_TEST 开关，控制应用代码（projects/）是否参与编译
# 子系统（CMSIS/zbus 等）的兼容性配置在此文件末尾
# 所有功能模块 Kconfig 由 projects/thread/Kconfig 统一 rsource

config PRJ_TEST
    bool "Test project"
    help
        测试项目
if PRJ_TEST
rsource "projects/thread/Kconfig"
endif


# HAS_CMSIS_CORE is defined in both modules/cmsis/Kconfig and modules/cmsis_6/Kconfig
# under an `if 0` block in modules/Kconfig, giving it dependency = n.
# Pre-define it here so deps resolve to y, preventing select-with-deps=n Kconfig errors.
config HAS_CMSIS_CORE
	bool

source "Kconfig.zephyr"

